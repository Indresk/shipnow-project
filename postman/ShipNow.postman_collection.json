{
  "info": {
    "name": "ShipNow API v1",
    "description": "Coleccion de la API baseline ShipNow (Backend 3 - CoderHouse). Usa la variable de coleccion {{baseUrl}} que por defecto apunta a http://localhost:8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Root",
      "item": [
        {
          "name": "GET / (health basico)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST crear user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana Lopez\",\n  \"email\": \"ana@example.com\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "GET listar users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "GET user por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "POST crear product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Caja mediana\",\n  \"price\": 200,\n  \"stock\": 20,\n  \"status\": \"available\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "GET listar products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "GET product por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", ":id"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        }
      ]
    },
    {
      "name": "Couriers",
      "item": [
        {
          "name": "POST crear courier",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Moto Express\",\n  \"zone\": \"Centro\",\n  \"available\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/couriers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "couriers"]
            }
          }
        },
        {
          "name": "GET listar couriers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/couriers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "couriers"]
            }
          }
        },
        {
          "name": "GET courier por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/couriers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "couriers", ":id"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "POST crear order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Ana Lopez\",\n  \"customer\": \"PEGAR_USER_ID_AQUI\",\n  \"address\": \"Calle Falsa 123\",\n  \"weight\": 5,\n  \"priority\": \"normal\",\n  \"items\": [\n    { \"name\": \"Caja chica\", \"quantity\": 2, \"price\": 100 }\n  ],\n  \"courierId\": \"PEGAR_COURIER_ID_AQUI\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "GET listar orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "GET order por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        },
        {
          "name": "PATCH order status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_transit\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id", "status"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        }
      ]
    },
    {
      "name": "Deliveries",
      "item": [
        {
          "name": "POST crear delivery",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"PEGAR_ORDER_ID_AQUI\",\n  \"courierId\": \"PEGAR_COURIER_ID_AQUI\",\n  \"status\": \"assigned\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/deliveries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries"]
            }
          }
        },
        {
          "name": "GET listar deliveries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries"]
            }
          }
        },
        {
          "name": "GET delivery por id (tracking)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", ":id"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        },
        {
          "name": "PATCH delivery status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_transit\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", ":id", "status"],
              "variable": [{ "key": "id", "value": "PEGAR_ID_AQUI" }]
            }
          }
        }
      ]
    }
  ]
}
